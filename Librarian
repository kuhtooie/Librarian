            s[i] = []
            for ii in range(len(self.shelves[i]))
                s[i][ii].append([])
                for iii in self.shelves[i][ii]:
                    if iii != pd.isna(ii):
                        s[i][ii].append(iii)
        self.shelves = s

    #Always place the book at the end of the shelf
